# Copy this file to .env.local for local development, and set the same
# variable in Vercel's project settings for the deployed site.
#
# Leave this UNSET (or delete the line) for local dev if you're running the
# backend on the same origin as the frontend (e.g. via a proxy) -- lib/apiBase.ts
# falls back to relative /api/... paths in that case, matching how this app
# worked through M3.
#
# Once the backend is deployed to Modal, set this to the URL `modal deploy`
# printed, e.g.:
NEXT_PUBLIC_API_URL=https://your-workspace--mathscan-api-fastapi-app.modal.run
